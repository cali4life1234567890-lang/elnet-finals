
@{
    ViewData["Title"] = "Index";
}

@model List<Vehicle>

<div class="container mt-4">
    <h2>Available Fleet</h2>

    <div class="row">
        @foreach (var v in Model)
        {
            <div class="col-md-4">
                <div class="card mb-4">
                    <img src="@v.ImageUrl" class="card-img-top" />
                    <div class="card-body">
                        <h5>@v.Name</h5>
                        <p>Capacity: @v.Capacity</p>
                        <p>$@v.PricePerHour / hour</p>

                        <a href="/Fleet/Details/@v.Id" class="btn btn-dark">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

