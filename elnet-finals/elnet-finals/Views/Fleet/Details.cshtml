@model elnet_finals.Models.Vehicle

@{
    ViewData["Title"] = $"{Model.Name} Details";
}

<div class="container mt-5">
    <h2 class="mb-4">@Model.Name</h2>
    <div class="row">
        <div class="col-md-5">
            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" />
        </div>
        <div class="col-md-7">
            <dl class="row">
                <dt class="col-sm-4">Type</dt>
                <dd class="col-sm-8">@Model.Type</dd>

                <dt class="col-sm-4">Capacity</dt>
                <dd class="col-sm-8">@Model.Capacity passengers</dd>

                <dt class="col-sm-4">Price per hour</dt>
                <dd class="col-sm-8">$@Model.PricePerHour</dd>

                <dt class="col-sm-4">Description</dt>
                <dd class="col-sm-8">@Model.Description</dd>
            </dl>
            <a asp-controller="Booking" asp-action="Step1" asp-route-vehicleId="@Model.Id" class="btn btn-primary mt-3">Book this bus</a>
            <a asp-action="Index" class="btn btn-secondary mt-3 ms-2">Back to List</a>
        </div>
    </div>
</div>
