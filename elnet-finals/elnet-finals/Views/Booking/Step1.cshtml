@model elnet_finals.Models.ViewModels.BookingStep1ViewModel

@{
    ViewData["Title"] = "Book " + Model.VehicleName;
}

<div class="container mt-5">
    <h2 class="mb-4">Booking: @Model.VehicleName</h2>
    <form asp-action="Details" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()
        <input type="hidden" asp-for="VehicleId" />
        <input type="hidden" asp-for="VehicleName" />

        <div class="mb-3">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" class="form-control" type="date" required />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="EndDate" class="form-label"></label>
            <input asp-for="EndDate" class="form-control" type="date" required />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Continue to Details</button>
        <a asp-controller="Fleet" asp-action="Index" class="btn btn-secondary ms-2">Back to Fleet</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
