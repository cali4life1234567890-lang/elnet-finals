@model IEnumerable<elnet_finals.Models.Booking>

@{
    ViewData["Title"] = "My Bookings";
}

<div class="container mt-5">
    <h2 class="mb-4">My Bookings</h2>
    @if (!Model.Any()) {
        <p>You have no bookings yet.</p>
    }
    else {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Booking Id</th>
                    <th>Vehicle</th>
                    <th>Period</th>
                    <th>Total Price</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    <tr>
                        <td>@booking.Id</td>
                        <td>@booking.Bus?.Name ?? "N/A"</td>
                        <td>@booking.StartDate.ToShortDateString() - @booking.EndDate.ToShortDateString()</td>
                        <td>@booking.TotalPrice:C</td>
                        <td>@booking.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Back to Home</a>
</div>
