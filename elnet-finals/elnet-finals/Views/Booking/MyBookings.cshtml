@using elnet_finals.Models
@model IEnumerable<elnet_finals.Models.Booking>

@{
    ViewData["Title"] = "My Bookings";
}

<h2 class="mt-4">My Bookings</h2>

@if (!Model.Any())
{
    <p>You have no bookings yet.</p>
}
else
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Booking Id</th>
                <th>Vehicle</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Total Price</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.Id</td>
                <td>@b.Bus?.Name ?? "N/A"</td>
                <td>@b.StartDate.ToShortDateString()</td>
                <td>@b.EndDate.ToShortDateString()</td>
                <td>$@b.TotalPrice</td>
            <td>
                @b.Status
                @if (b.Status != BookingStatus.Cancelled) {
                    <form asp-action="Cancel" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@b.Id" />
                        <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                        @Html.AntiForgeryToken()
                    </form>
                }
            </td>
            </tr>
        }
        </tbody>
    </table>
}
