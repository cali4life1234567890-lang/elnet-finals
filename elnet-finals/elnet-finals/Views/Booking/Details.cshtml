@model elnet_finals.Models.ViewModels.BookingDetailsViewModel

@{ 
    ViewData["Title"] = "Booking Details for " + Model.VehicleName; 
}

<div class="container mt-5">
    <h2 class="mb-4">Additional Details for @Model.VehicleName</h2>
    <form asp-controller="Booking" asp-action="Confirm" method="post" class="needs-validation" novalidate>
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <input type="hidden" asp-for="VehicleId" />
        <input type="hidden" asp-for="VehicleName" />
        <input type="hidden" asp-for="StartDate" />
        <input type="hidden" asp-for="EndDate" />

        <div class="mb-3">
            <label asp-for="PickupLocation" class="form-label"></label>
            <input asp-for="PickupLocation" class="form-control" required />
            <span asp-validation-for="PickupLocation" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Destination" class="form-label"></label>
            <input asp-for="Destination" class="form-control" required />
            <span asp-validation-for="Destination" class="text-danger"></span>
        </div>
        <div class="form-check mb-2">
            <input asp-for="WiFi" class="form-check-input" type="checkbox" />
            <label asp-for="WiFi" class="form-check-label"></label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Insurance" class="form-check-input" type="checkbox" />
            <label asp-for="Insurance" class="form-check-label"></label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="ExtraLuggage" class="form-check-input" type="checkbox" />
            <label asp-for="ExtraLuggage" class="form-check-label"></label>
        </div>
        <button type="submit" class="btn btn-primary">Confirm Booking</button>
        <a asp-controller="Fleet" asp-action="Index" class="btn btn-secondary ms-2">Back to Fleet</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
